{
    "name": "joao-aschenbrenner/schf-connectors",
    "description": "Universal database connectors for SCHF Migration Framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SCHF\\Connectors\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../schf-sdk",
            "options": {
                "symlink": false
            }
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-pdo": "*",
        "joao-aschenbrenner/schf-sdk": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    }
}
